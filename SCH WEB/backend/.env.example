# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration (unused — Resend below is what's actually wired up)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Resend Configuration (transactional email: contact/admissions/careers
# confirmations, password reset links) — get a key at resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Termii Configuration (SMS: portal login credentials, password reset links —
# needed since not every parent has email but everyone has a phone number)
# Get a key at termii.com; TERMII_SENDER_ID must be a sender ID approved in
# your Termii dashboard before real messages will actually deliver.
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=GMASchool

# Paystack Configuration (for later use)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Cloudinary Configuration (file uploads: passport photos, documents, cover letters)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Server Configuration
PORT=5000
NODE_ENV=development

# Public frontend URL — used to build links in emails (e.g. password reset)
FRONTEND_URL=http://localhost:5173
